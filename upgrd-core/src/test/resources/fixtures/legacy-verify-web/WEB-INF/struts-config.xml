<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts-config PUBLIC
  "-//Apache Software Foundation//DTD Struts Configuration 1.3//EN"
  "http://struts.apache.org/dtds/struts-config_1_3.dtd">
<struts-config>
  <form-beans>
    <form-bean name="loginForm" type="com.demo.verify.LoginForm"/>
  </form-beans>
  <action-mappings>
    <action path="/login" type="com.demo.verify.LoginAction" name="loginForm" scope="request">
      <forward name="success" path="/pages/home.jsp"/>
      <forward name="input" path="/pages/login.jsp"/>
    </action>
    <action path="/report" type="com.demo.verify.ReportAction" scope="request">
      <forward name="success" path="/pages/report.jsp"/>
    </action>
    <action path="/admin" type="com.demo.verify.AdminAction" scope="request">
      <forward name="success" path="/pages/admin.jsp"/>
    </action>
  </action-mappings>
</struts-config>
